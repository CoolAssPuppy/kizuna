{
  "name": "kizuna",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "description": "Event and community platform for Supafest, built natively on Supabase",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "dev": "if command -v doppler >/dev/null 2>&1; then doppler run -- vite; else vite; fi",
    "build": "if command -v doppler >/dev/null 2>&1; then doppler run -- sh -c 'tsc -b && vite build'; else sh -c 'tsc -b && vite build'; fi",
    "preview": "if command -v doppler >/dev/null 2>&1; then doppler run -- vite preview; else vite preview; fi",
    "typecheck": "tsc -b --noEmit",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write \"src/**/*.{ts,tsx,css,json,md}\" \"tests/**/*.{ts,tsx}\" \"*.{json,md,ts}\"",
    "format:check": "prettier --check \"src/**/*.{ts,tsx,css,json,md}\"",
    "test": "vitest",
    "test:run": "vitest run",
    "test:coverage": "vitest run --coverage",
    "test:ui": "vitest --ui",
    "test:e2e": "if command -v doppler >/dev/null 2>&1; then doppler run -- playwright test; else playwright test; fi",
    "test:e2e:ui": "if command -v doppler >/dev/null 2>&1; then doppler run -- playwright test --ui; else playwright test --ui; fi",
    "db:start": "supabase start",
    "db:stop": "supabase stop",
    "db:reset": "supabase db reset",
    "db:apply": "bash scripts/db-apply.sh",
    "db:diff": "supabase db diff -f",
    "db:test": "supabase test db",
    "gen:types": "supabase gen types typescript --local --schema public > src/types/database.types.ts",
    "simulate:community": "if command -v doppler >/dev/null 2>&1; then doppler run -- tsx scripts/simulate-community.ts; else tsx scripts/simulate-community.ts; fi",
    "prepare": "husky 2>/dev/null || true"
  },
  "dependencies": {
    "@radix-ui/react-checkbox": "^1.3.3",
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-label": "^2.1.8",
    "@radix-ui/react-progress": "^1.1.8",
    "@radix-ui/react-slot": "^1.1.0",
    "@supabase/supabase-js": "^2.45.4",
    "@tanstack/react-query": "^5.59.0",
    "class-variance-authority": "^0.7.0",
    "clsx": "^2.1.1",
    "i18next": "^23.16.0",
    "i18next-browser-languagedetector": "^8.0.0",
    "lucide-react": "^1.14.0",
    "qrcode.react": "^4.2.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-dropzone": "^15.0.0",
    "react-i18next": "^15.0.3",
    "react-markdown": "^10.1.0",
    "react-router-dom": "^6.26.2",
    "react-simple-maps": "^3.0.0",
    "recharts": "^3.8.1",
    "remark-gfm": "^4.0.1",
    "tailwind-merge": "^2.5.3",
    "tailwindcss-animate": "^1.0.7"
  },
  "devDependencies": {
    "@playwright/test": "^1.48.0",
    "@testing-library/jest-dom": "^6.5.0",
    "@testing-library/react": "^16.0.1",
    "@testing-library/user-event": "^14.5.2",
    "@types/node": "^25.6.0",
    "@types/react": "^18.3.11",
    "@types/react-dom": "^18.3.0",
    "@types/react-simple-maps": "^3.0.6",
    "@typescript-eslint/eslint-plugin": "^8.8.0",
    "@typescript-eslint/parser": "^8.8.0",
    "@vitejs/plugin-react": "^6.0.1",
    "@vitest/coverage-v8": "^4.1.5",
    "autoprefixer": "^10.4.20",
    "eslint": "^10.2.1",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-jsx-a11y": "^6.10.0",
    "eslint-plugin-react": "^7.37.1",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.5.0",
    "happy-dom": "^20.9.0",
    "husky": "^9.1.6",
    "lint-staged": "^16.4.0",
    "postcss": "^8.4.47",
    "prettier": "^3.3.3",
    "prettier-plugin-tailwindcss": "^0.8.0",
    "tailwindcss": "^4.2.4",
    "tsx": "^4.21.0",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.8.0",
    "vite": "^8.0.10",
    "vite-plugin-pwa": "^1.2.0",
    "vitest": "^4.1.5",
    "world-atlas": "^2.0.2"
  },
  "overrides": {
    "d3-color": "^3.1.0"
  },
  "lint-staged": {
    "*.{ts,tsx}": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.{json,md,css}": [
      "prettier --write"
    ]
  }
}
