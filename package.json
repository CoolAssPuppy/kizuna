{
  "name": "kizuna",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "description": "Event and community platform for Supafest, built natively on Supabase",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "dev": "bash scripts/with-doppler.sh vite",
    "build": "bash scripts/with-doppler.sh sh -c 'tsc -b && vite build'",
    "preview": "bash scripts/with-doppler.sh vite preview",
    "typecheck": "tsc -b --noEmit",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write \"src/**/*.{ts,tsx,css,json,md}\" \"tests/**/*.{ts,tsx}\" \"*.{json,md,ts}\"",
    "format:check": "prettier --check \"src/**/*.{ts,tsx,css,json,md}\"",
    "test": "vitest",
    "test:run": "vitest run",
    "test:coverage": "vitest run --coverage",
    "test:ui": "vitest --ui",
    "test:e2e": "bash scripts/with-doppler.sh playwright test",
    "test:e2e:ui": "bash scripts/with-doppler.sh playwright test --ui",
    "security:check-env": "node scripts/check-vite-env-secrets.mjs",
    "db:start": "supabase start",
    "db:stop": "supabase stop",
    "db:reset": "supabase db reset",
    "db:apply": "bash scripts/db-apply.sh",
    "db:diff": "supabase db diff -f",
    "db:test": "supabase test db",
    "functions:env": "doppler secrets download --project kizuna --config dev --no-file --format env > supabase/.env",
    "functions:serve": "npm run functions:env && supabase functions serve --env-file supabase/.env",
    "gen:types": "supabase gen types typescript --local --schema public > src/types/database.types.ts",
    "gen:og": "node scripts/generate-og.mjs",
    "simulate:community": "bash scripts/with-doppler.sh tsx scripts/simulate-community.ts",
    "seed:remote-users": "tsx scripts/seed-remote-users.ts",
    "prepare": "husky 2>/dev/null || true",
    "postinstall": "test -f public/world-110m.json || cp node_modules/world-atlas/countries-110m.json public/world-110m.json"
  },
  "dependencies": {
    "@radix-ui/react-checkbox": "^1.3.3",
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-label": "^2.1.8",
    "@radix-ui/react-progress": "^1.1.8",
    "@radix-ui/react-slot": "^1.1.0",
    "@supabase/supabase-js": "^2.45.4",
    "@tanstack/react-query": "^5.59.0",
    "@vitest/ui": "^4.1.5",
    "class-variance-authority": "^0.7.0",
    "clsx": "^2.1.1",
    "html5-qrcode": "^2.3.8",
    "i18next": "^23.16.0",
    "i18next-browser-languagedetector": "^8.0.0",
    "lucide-react": "^1.14.0",
    "qrcode.react": "^4.2.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-dropzone": "^15.0.0",
    "react-i18next": "^15.0.3",
    "react-markdown": "^10.1.0",
    "react-router-dom": "^6.26.2",
    "react-simple-maps": "^3.0.0",
    "recharts": "^3.8.1",
    "remark-gfm": "^4.0.1",
    "tailwind-merge": "^2.5.3",
    "tailwindcss-animate": "^1.0.7"
  },
  "devDependencies": {
    "@playwright/test": "^1.48.0",
    "@resvg/resvg-js": "^2.6.2",
    "@testing-library/jest-dom": "^6.5.0",
    "@testing-library/react": "^16.0.1",
    "@testing-library/user-event": "^14.5.2",
    "@types/node": "^22.7.4",
    "@types/react": "^18.3.11",
    "@types/react-dom": "^18.3.0",
    "@types/react-simple-maps": "^3.0.6",
    "@typescript-eslint/eslint-plugin": "^8.8.0",
    "@typescript-eslint/parser": "^8.8.0",
    "@vitejs/plugin-react": "^4.3.2",
    "@vitest/coverage-v8": "^4.1.5",
    "autoprefixer": "^10.4.20",
    "eslint": "^9.12.0",
    "eslint-config-prettier": "^9.1.0",
    "eslint-plugin-jsx-a11y": "^6.10.0",
    "eslint-plugin-react": "^7.37.1",
    "eslint-plugin-react-hooks": "^5.0.0",
    "eslint-plugin-react-refresh": "^0.4.12",
    "globals": "^15.10.0",
    "happy-dom": "^20.9.0",
    "husky": "^9.1.6",
    "lint-staged": "^15.2.10",
    "postcss": "^8.4.47",
    "prettier": "^3.3.3",
    "prettier-plugin-tailwindcss": "^0.6.8",
    "tailwindcss": "^3.4.13",
    "tsx": "^4.21.0",
    "typescript": "^5.6.2",
    "typescript-eslint": "^8.8.0",
    "vite": "^7.3.2",
    "vite-plugin-pwa": "^1.2.0",
    "vitest": "^4.1.5",
    "world-atlas": "^2.0.2"
  },
  "overrides": {
    "d3-color": "^3.1.0",
    "@rollup/plugin-terser": "^1.0.0",
    "serialize-javascript": "^7.0.5"
  },
  "lint-staged": {
    "*.{ts,tsx}": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.{json,md,css}": [
      "prettier --write"
    ]
  }
}
