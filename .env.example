# Public client config — safe to expose in browser bundle
VITE_SUPABASE_URL=http://127.0.0.1:54321
VITE_SUPABASE_PUBLISHABLE_KEY=

# Server-only secrets (never expose with VITE_ prefix)
# These belong in supabase/functions/.env or in your hosting platform.
SUPABASE_URL=http://127.0.0.1:54321
SUPABASE_SECRET_KEY=

# External integrations — when missing, app degrades gracefully
HIBOB_API_KEY=
HIBOB_WEBHOOK_SECRET=
OKTA_DOMAIN=
OKTA_CLIENT_ID=
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
RESEND_API_KEY=
RESEND_FROM_EMAIL=hello@kizuna.example
SLACK_BOT_TOKEN=
SLACK_SIGNING_SECRET=
NOTION_API_KEY=

# Misc
KIZUNA_ENV=development
