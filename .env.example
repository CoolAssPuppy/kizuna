# Kizuna environment variables
# -----------------------------
# Copy this file to .env and fill in real values. The values shipped here are
# safe placeholders; the app degrades gracefully when integration credentials
# are missing (see CLAUDE.md "Fail gracefully without integration credentials").
#
# Anything prefixed VITE_ is bundled into the browser. Never put a server
# secret behind a VITE_ prefix.


# === Required for local dev ===

# Local Supabase publishable key. The default below matches what
# `supabase start` prints on a fresh kizuna project. Run `supabase status`
# to copy yours and paste into .env.
VITE_SUPABASE_URL=http://127.0.0.1:54321
VITE_SUPABASE_PUBLISHABLE_KEY=sb_publishable_ACJWlzQHlZjBrEguHvfOxg_3BJgxAaH


# === Optional client config ===

# Employee SSO. With both vars set, the Sign In screen calls
# supabase.auth.signInWithSSO({ domain }) against the registered Okta
# domain. Without them, the dev fallback signs in prashant@kizuna.dev
# with the seeded password (see supabase/seed.sql).
VITE_OKTA_DOMAIN=
VITE_OKTA_CLIENT_ID=


# === Server-only (edge functions) ===
# These belong in supabase/functions/.env locally and in your hosting
# platform's secret store in production. NEVER prefix with VITE_.

# Supabase service role / secret key. Only used inside edge functions.
SUPABASE_URL=http://127.0.0.1:54321
SUPABASE_SECRET_KEY=

# HMAC secret for signing guest invitation JWTs. 7-day expiry default.
# Anything random and at least 32 characters works.
KIZUNA_INVITATION_SECRET=change-me-to-a-long-random-string

# pgcrypto symmetric key for passport_number encryption. Set on the
# database via `alter database postgres set kizuna.passport_key = '...';`
# Edge functions and the SPA never see this directly.
KIZUNA_PASSPORT_KEY=change-me-to-another-long-random-string

# Public-facing URL for invitation accept links. Override in production.
KIZUNA_PUBLIC_URL=http://localhost:5173


# === Integrations (graceful when blank) ===

# HiBob employee directory. When blank, the sync edge function logs and
# returns mock data; conflicts are still tracked.
HIBOB_API_KEY=
HIBOB_WEBHOOK_SECRET=

# Perk travel. Phase 1 reads the CSV export; the API integration arrives
# in Phase 4.
PERK_API_KEY=

# Stripe. Adult guest fee $950, child 12+ $500. Webhook signature is
# HMAC-verified when STRIPE_WEBHOOK_SECRET is set.
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# Resend. Transactional email for guests. Falls back to in-memory outbox
# in dev so the invitation/accept flow completes without sending real
# email.
RESEND_API_KEY=
RESEND_FROM_EMAIL=hello@kizuna.example

# Slack. Targeted DMs to employees only — never broadcasts. Rate-limited
# to one nudge per task per three days.
SLACK_BOT_TOKEN=
SLACK_SIGNING_SECRET=

# Notion. Read-only sync of informational documents. Legal documents
# (waiver, code of conduct) are always Kizuna-native and never synced.
NOTION_API_KEY=

# OpenAI. Powers the parse-itinerary edge function (free-text email →
# structured flights, hotels, transfers). When blank the function logs
# a warning and returns an empty itinerary so the UI still renders.
OPENAI_API_KEY=
# Optional override; defaults to gpt-4o-mini in code.
OPENAI_MODEL=

# Anthropic. Reserved for future LLM workloads (document summarisation,
# admin assistance). Edge functions degrade gracefully when this is
# blank, so leaving it empty is safe in dev.
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=


# === Misc ===

# Tag your environment so logs and shareable report links are unambiguous.
KIZUNA_ENV=development
